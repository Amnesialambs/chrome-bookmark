{
    "manifest_version": 3,
    "name": "Chrome浏览器书签同步管理工具",
    "description": "Chrome书签同步管理工具，一个不需要VPN就能访问的书签工具！",
    "version": "1.0",
    "permissions": [
        "notifications",
        "bookmarks", 
        "storage"
    ],
    "host_permissions": [
        "http://*/*", 
        "https://*/*"
    ],
    "icons": {
        "16": "img/icon.png",
        "48": "img/icon.png",
        "128": "img/icon.png"
    },
    "action": {
        "default_icon": "img/icon.png",
        "default_title": "Chrome浏览器书签同步管理工具",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "js/background.js"
    },
    "omnibox": {"keyword": "go"},
    "homepage_url": "https://gitee.com/CLCoding/chrome-bookmark"
}